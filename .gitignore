# =============================================================================
# NotebookLM Customer Feedback Intelligence System
# .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SENSITIVE FEEDBACK DATA
# Raw customer feedback files should never be committed to the repository.
# Store them locally or in a secure, private storage solution.
# -----------------------------------------------------------------------------
/data/
/feedback/
/raw-feedback/
*.pdf
*.csv
*.xlsx
*.xls

# -----------------------------------------------------------------------------
# PERSONAL & CONFIDENTIAL OUTPUTS
# Analysis outputs may contain sensitive customer information.
# -----------------------------------------------------------------------------
/outputs/
/exports/
/analysis-results/
*-private.*
*-confidential.*
*-internal.*

# -----------------------------------------------------------------------------
# OPERATING SYSTEM FILES
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# -----------------------------------------------------------------------------
# EDITORS & IDEs
# -----------------------------------------------------------------------------

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
*~
Session.vim

# Sublime Text
*.sublime-project
*.sublime-workspace

# Cursor
.cursor/

# -----------------------------------------------------------------------------
# PYTHON (if scripts are added to automate PDF processing)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
env/
venv/
.env
.venv
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
htmlcov/
dist/
build/
*.egg-info/
.eggs/

# -----------------------------------------------------------------------------
# NODE / JAVASCRIPT (if tooling is added in the future)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.env.local
.env.development.local
.env.test.local
.env.production.local

# -----------------------------------------------------------------------------
# ENVIRONMENT & SECRETS
# Never commit API keys, tokens, or credentials of any kind.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
secrets/
credentials/
config/local.*

# -----------------------------------------------------------------------------
# LOGS & TEMPORARY FILES
# -----------------------------------------------------------------------------
*.log
logs/
temp/
tmp/
*.tmp
*.bak
*.backup
*.orig

# -----------------------------------------------------------------------------
# RICE MATRIX WORKING FILES
# Keep only the final template in the repo, not personal working copies.
# -----------------------------------------------------------------------------
rice-working/
*-draft.*
*-wip.*
